# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_NAME=prueba-omc
APP_ENV=development  # development | staging | production

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
POSTGRES_DB_DEBUG=false
POSTGRES_DB_HOST=postgres         # Use 'localhost' when running outside Docker
POSTGRES_DB_PORT=5432
POSTGRES_DB_NAME=omc_db
POSTGRES_DB_USER=omc_user
POSTGRES_DB_PASSWORD=change_me_in_production
POSTGRES_DB_DRIVER=postgresql+asyncpg

# Database Connection Pool
DB_POOL_SIZE=100
DB_POOL_MAX_OVERFLOW=50
DB_POOL_RECYCLE=120
DB_POOL_PRE_PING=true

# =============================================================================
# JWT / AUTHENTICATION CONFIGURATION
# =============================================================================
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=omc-api.com
JWT_AUDIENCE=omc-api-users
COOKIE_SECURE=false               # Set to true in production (HTTPS)
COOKIE_SAMESITE=lax               # lax | strict | none

# =============================================================================
# DEFAULT ADMIN USER (seed)
# =============================================================================
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=change_me_in_production

# =============================================================================
# AI / OPENAI CONFIGURATION
# =============================================================================
AI_API_KEY=sk-your-openai-api-key-here
AI_MODEL=gpt-4o-mini
